# Local dev works without this file.
# If you create .env for local development, these defaults use SQLite.

# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev database.
# npm run dev automatically uses prisma/dev.db.
DATABASE_URL=file:./dev.db

# Redis is optional in dev. Leave empty to use in-memory rate limits.
REDIS_URL=

# Auth
JWT_ACCESS_SECRET=auraai_dev_access_secret_32_chars_min
JWT_REFRESH_SECRET=auraai_dev_refresh_secret_32_chars_min
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=30

# Limits
REQUEST_LIMIT_PER_MINUTE=120
REQUEST_BODY_LIMIT_MB=4
INTERNAL_API_TIMEOUT_MS=90000
DEFAULT_NEW_USER_TOKENS=100000

# Providers. Fill at least one for real AI proxy calls.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Payments (optional now, required when enabling providers in UI)
YOOMONEY_WALLET=4100119511697667
SBP_MERCHANT_ID=
CRYPTOBOT_TOKEN=
HELEKET_MERCHANT_ID=
LZT_SHOP_ID=

# Seed admin
ADMIN_EMAIL=admin@auraai.local
ADMIN_PASSWORD=ChangeMe123!

# Production/Amvera:
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@host:5432/auraai
# REDIS_URL=redis://host:6379
# JWT_ACCESS_SECRET=<unique 32+ char secret>
# JWT_REFRESH_SECRET=<unique 32+ char secret>
# NEXT_PUBLIC_APP_URL=https://your-domain.com
