{
  "name": "auraai",
  "version": "0.1.0",
  "description": "AuraAI - OpenAI-compatible AI proxy platform",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev": "node scripts/dev-server.cjs",
    "build": "prisma generate --schema prisma/schema.prisma && next build",
    "start": "cross-env NODE_ENV=production node server.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "cross-env NODE_ENV=development node scripts/dev-bootstrap.cjs --skip-seed",
    "prisma:pg:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:dev": "cross-env NODE_ENV=development node scripts/dev-bootstrap.cjs"
  },
  "keywords": [
    "nextjs",
    "openai-compatible",
    "proxy",
    "auraai"
  ],
  "author": "AuraAI",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "prisma": "^6.17.1",
    "rate-limiter-flexible": "^11.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
